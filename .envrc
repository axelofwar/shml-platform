# direnv — auto-activates .venv when entering this directory.
# Install direnv: https://direnv.net/  then run: direnv allow
#
# This ensures all platform scripts run in the correct venv — NOT system python.
# Critical deps in .venv: pyspark, polars, mlflow, asyncpg, psycopg2-binary
# Run `pip install -r requirements.txt` to install/update.

layout python3
source .venv/bin/activate
