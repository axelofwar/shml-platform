[Unit]
Description=Ray Compute and MLflow Platform Services
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=axelofwar
WorkingDirectory=/opt
ExecStart=/opt/start_all_services.sh
ExecStop=/opt/stop_all_services.sh
TimeoutStartSec=300
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
