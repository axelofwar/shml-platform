{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwopus/qwopus-coding",
  "provider": {
    "qwopus": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwopus (local via agent-service)",
      "options": {
        "baseURL": "http://localhost:8099/v1"
      },
      "models": {
        "qwopus-coding": {
          "name": "Qwopus-27B Q4_K_M (Local)",
          "tool_call": true,
          "reasoning": true,
          "attachment": false,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    }
  },
  "tools": {
    "read": true,
    "write": true,
    "edit": true,
    "bash": true,
    "grep": true,
    "glob": true,
    "list": true,
    "webfetch": true,
    "todowrite": true,
    "todoread": true,
    "patch": true
  },
  "mcp": {
    "shml-platform": {
      "type": "http",
      "url": "http://localhost:8000/mcp",
      "timeout": 120000
    },
    "gitnexus": {
      "type": "stdio",
      "command": "gitnexus",
      "args": [
        "mcp"
      ],
      "timeout": 30000
    },
    "gitlab": {
      "type": "stdio",
      "command": "/home/axelofwar/Projects/shml-platform/scripts/mcp/run-gitlab-mcp.sh",
      "timeout": 30000
    },
    "prometheus": {
      "type": "stdio",
      "command": "/home/axelofwar/Projects/shml-platform/scripts/mcp/run-prometheus-mcp.sh",
      "timeout": 15000
    }
  }
}
