# ML Platform Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   # Edit .env with your generated secrets
#
# Generate secure passwords with:
#   openssl rand -base64 32

# =============================================================================
# AUTHENTIK (OAuth/Identity Provider)
# =============================================================================
# Secret key for Authentik encryption (REQUIRED)
# Generate: openssl rand -base64 50
AUTHENTIK_SECRET_KEY=

# PostgreSQL password for Authentik database (REQUIRED)
# Generate: openssl rand -base64 32
AUTHENTIK_DB_PASSWORD=

# Bootstrap password for akadmin user (first login only)
# After first login, change via Authentik UI
AUTHENTIK_BOOTSTRAP_PASSWORD=

# =============================================================================
# OAUTH CLIENT CREDENTIALS (Optional - for OAuth integration)
# =============================================================================
# Create these in Authentik admin panel after first setup
# Admin URL: http://localhost:9000/if/admin/
MLFLOW_OAUTH_CLIENT_ID=
MLFLOW_OAUTH_CLIENT_SECRET=
RAY_OAUTH_CLIENT_ID=
RAY_OAUTH_CLIENT_SECRET=

# =============================================================================
# GRAFANA (Monitoring Dashboards)
# =============================================================================
# Admin password for unified Grafana instance
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# SHARED POSTGRESQL (MLflow, Ray Compute, Inference)
# =============================================================================
# Single password for shared PostgreSQL instance
# Databases: mlflow_db, ray_compute, inference
# Generate: openssl rand -base64 32
SHARED_DB_PASSWORD=

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Your Tailscale IP (for remote access)
# Get with: tailscale ip -4
TAILSCALE_IP=

# =============================================================================
# QUICK SETUP
# =============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate all secrets at once:
#    echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 50)" >> .env
#    echo "AUTHENTIK_DB_PASSWORD=$(openssl rand -base64 32)" >> .env
#    echo "AUTHENTIK_BOOTSTRAP_PASSWORD=$(openssl rand -base64 24)" >> .env
#    echo "GRAFANA_ADMIN_PASSWORD=$(openssl rand -base64 24)" >> .env
#    echo "SHARED_DB_PASSWORD=$(openssl rand -base64 32)" >> .env
#    echo "TAILSCALE_IP=$(tailscale ip -4 2>/dev/null || echo 'YOUR_IP')" >> .env
#
# 3. Start the platform:
#    ./start_all_safe.sh
#
# =============================================================================
# CREDENTIAL ACCESS
# =============================================================================
# View all secrets:
#   grep -E "(PASSWORD|SECRET|KEY)" .env
#
# Authentik admin login:
#   URL: http://localhost:9000/
#   User: akadmin
#   Password: $AUTHENTIK_BOOTSTRAP_PASSWORD (first login only)
#
# Grafana login:
#   URL: http://localhost/grafana/
#   User: admin
#   Password: $GRAFANA_ADMIN_PASSWORD
