# ML Platform Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   # Edit .env with your generated secrets
#
# Generate secure passwords with:
#   openssl rand -base64 32

# =============================================================================
# AUTHENTIK (OAuth/Identity Provider)
# =============================================================================
# Secret key for Authentik encryption (REQUIRED)
# Generate: openssl rand -base64 50
AUTHENTIK_SECRET_KEY=

# PostgreSQL password for Authentik database (REQUIRED)
# Generate: openssl rand -base64 32
AUTHENTIK_DB_PASSWORD=

# Bootstrap password for akadmin user (first login only)
# After first login, change via Authentik UI
AUTHENTIK_BOOTSTRAP_PASSWORD=

# =============================================================================
# FUSIONAUTH (OAuth/Identity Provider - Migration Target)
# =============================================================================
# Runtime mode: development or production
FUSIONAUTH_RUNTIME_MODE=development

# Admin password for first setup
FUSIONAUTH_ADMIN_PASSWORD=

# API key for programmatic access (generate with: openssl rand -hex 32)
FUSIONAUTH_API_KEY=

# OAuth client secrets for applications
FUSIONAUTH_MLFLOW_CLIENT_SECRET=
FUSIONAUTH_RAY_CLIENT_SECRET=

# =============================================================================
# OAUTH CLIENT CREDENTIALS (Optional - for OAuth integration)
# =============================================================================
# Create these in Authentik admin panel after first setup
# Admin URL: http://localhost:9000/if/admin/
MLFLOW_OAUTH_CLIENT_ID=
MLFLOW_OAUTH_CLIENT_SECRET=
RAY_OAUTH_CLIENT_ID=
RAY_OAUTH_CLIENT_SECRET=

# =============================================================================
# GRAFANA (Monitoring Dashboards)
# =============================================================================
# Admin password for unified Grafana instance
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# SHARED POSTGRESQL (MLflow, Ray Compute, Inference)
# =============================================================================
# Single password for shared PostgreSQL instance
# Databases: mlflow_db, ray_compute, inference
# Generate: openssl rand -base64 32
SHARED_DB_PASSWORD=

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Your Tailscale IP (for remote access)
# Get with: tailscale ip -4
TAILSCALE_IP=

# Public domain for external access (Tailscale Funnel)
PUBLIC_DOMAIN=sfml-platform.tail38b60a.ts.net

# =============================================================================
# NOTIFICATIONS (Telegram & Email)
# =============================================================================
# Telegram Bot Token (create via @BotFather on Telegram)
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow prompts
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (get via @userinfobot or @getidsbot)
# 1. Message @userinfobot on Telegram
# 2. It will reply with your chat ID
TELEGRAM_CHAT_ID=

# Email for deployment notifications (optional)
DEPLOY_NOTIFICATION_EMAIL=

# =============================================================================
# GITHUB WEBHOOKS (Push-to-Deploy)
# =============================================================================
# GitHub Webhook Secret (generate with: openssl rand -hex 32)
# Set this same secret in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Backup schedule (cron format, default: 2 AM daily)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# Optional: Webhook URL for backup notifications
BACKUP_WEBHOOK_URL=

# =============================================================================
# RESOURCE LIMITS (Auto-detected or manual override)
# =============================================================================
# Run ./scripts/detect_resources.sh to generate recommended values
# Or set manually below. Leave empty to use defaults.

# Observability Stack
DOZZLE_CPU_LIMIT=
DOZZLE_MEM_LIMIT=
HOMEPAGE_CPU_LIMIT=
HOMEPAGE_MEM_LIMIT=
UPTIME_KUMA_CPU_LIMIT=
UPTIME_KUMA_MEM_LIMIT=
BACKUP_CPU_LIMIT=
BACKUP_MEM_LIMIT=
WEBHOOK_CPU_LIMIT=
WEBHOOK_MEM_LIMIT=

# =============================================================================
# API SECURITY (Optional - for API key authentication)
# =============================================================================
# Enable API key authentication (default: false for local/trusted networks)
# API_KEY_ENABLED=false

# API secret key for JWT signing (required if API_KEY_ENABLED=true)
# Generate: openssl rand -base64 50
# RAY_API_SECRET_KEY=

# Session secret for OAuth middleware
# Generate: openssl rand -base64 50
# SESSION_SECRET_KEY=

# API keys for tiered access (optional)
# Generate: openssl rand -base64 32
# ADMIN_API_KEY=
# PREMIUM_API_KEY=

# =============================================================================
# QUICK SETUP
# =============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate all secrets at once:
#    echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 50)" >> .env
#    echo "AUTHENTIK_DB_PASSWORD=$(openssl rand -base64 32)" >> .env
#    echo "AUTHENTIK_BOOTSTRAP_PASSWORD=$(openssl rand -base64 24)" >> .env
#    echo "GRAFANA_ADMIN_PASSWORD=$(openssl rand -base64 24)" >> .env
#    echo "SHARED_DB_PASSWORD=$(openssl rand -base64 32)" >> .env
#    echo "TAILSCALE_IP=$(tailscale ip -4 2>/dev/null || echo 'YOUR_IP')" >> .env
#
# 3. Start the platform:
#    ./start_all_safe.sh
#
# =============================================================================
# CREDENTIAL ACCESS
# =============================================================================
# View all secrets:
#   grep -E "(PASSWORD|SECRET|KEY)" .env
#
# Authentik admin login:
#   URL: http://localhost:9000/
#   User: akadmin
#   Password: $AUTHENTIK_BOOTSTRAP_PASSWORD (first login only)
#
# Grafana login:
#   URL: http://localhost/grafana/
#   User: admin
#   Password: $GRAFANA_ADMIN_PASSWORD
