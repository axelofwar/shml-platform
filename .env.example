# ML Platform Environment Configuration
# =====================================
# Copy this file to .env and customize for your deployment:
#   cp .env.example .env
#
# Generate secure passwords:
#   openssl rand -base64 32

# =============================================================================
# PLATFORM IDENTITY
# =============================================================================
# Prefix used for all service names, container names, volumes, and networks
# Change this to deploy multiple instances or rebrand the platform
# Examples: shml, ml-lab, ai-platform
PLATFORM_PREFIX=shml

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# TAILSCALE CONFIGURATION
# -----------------------
# Get your Tailscale IP with: tailscale ip -4
# The PUBLIC_DOMAIN is your Tailscale funnel hostname
TAILSCALE_IP=100.66.26.115

# LAN IP (Traefik binds here, leaving Tailscale IP free for serve/funnel)
# Get with: ip addr show | grep "inet " | grep -v 127.0.0.1 | grep -v tailscale | head -1
LAN_IP=10.0.0.163

# Public domain via Tailscale Funnel (format: <hostname>.<tailnet-id>.ts.net)
PUBLIC_DOMAIN=your-hostname.tailnet-id.ts.net

# =============================================================================
# SHARED POSTGRESQL
# =============================================================================
# Single password for shared PostgreSQL instance
# Databases: mlflow_db, ray_compute, inference, fusionauth
# Generate: openssl rand -base64 32
SHARED_DB_PASSWORD=

# =============================================================================
# FUSIONAUTH (OAuth/Identity Provider)
# =============================================================================
# Runtime mode: development or production
FUSIONAUTH_RUNTIME_MODE=development

# Admin password for first setup
FUSIONAUTH_ADMIN_PASSWORD=

# FusionAuth license key (for community edition, get from fusionauth.io)
FUSIONAUTH_LICENSE_KEY=

# API key for programmatic access (generate with: openssl rand -hex 32)
FUSIONAUTH_API_KEY=

# Application-specific API keys (optional - for CI/CD integration)
FUSIONAUTH_MLFLOW_API_KEY=
FUSIONAUTH_CICD_SUPER_KEY=
FUSIONAUTH_CICD_DEVELOPER_KEY=
FUSIONAUTH_CICD_VIEWER_KEY=

# OAuth client IDs and secrets for applications
# These are generated in FusionAuth admin panel
FUSIONAUTH_MLFLOW_CLIENT_ID=
FUSIONAUTH_MLFLOW_CLIENT_SECRET=
FUSIONAUTH_RAY_CLIENT_ID=
FUSIONAUTH_RAY_CLIENT_SECRET=
FUSIONAUTH_GRAFANA_CLIENT_ID=
FUSIONAUTH_GRAFANA_CLIENT_SECRET=
FUSIONAUTH_PROXY_CLIENT_ID=
FUSIONAUTH_PROXY_CLIENT_SECRET=

# FusionAuth OIDC Issuer - must match PUBLIC_DOMAIN for OAuth2 Proxy
FUSIONAUTH_ISSUER=https://your-hostname.tailnet-id.ts.net

# =============================================================================
# EXTERNAL OAUTH PROVIDERS (Optional)
# =============================================================================
# Google OAuth (create at console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth (create at github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Twitter/X OAuth (create at developer.twitter.com)
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=

# =============================================================================
# OAUTH2-PROXY (Forward Authentication)
# =============================================================================
# Cookie secret for OAuth2 Proxy (must be 16, 24, or 32 bytes base64 encoded)
# Generate: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=

# OAuth2-Proxy Application ID in FusionAuth (used by recovery scripts)
OAUTH2_PROXY_APP_ID=

# =============================================================================
# GRAFANA (Monitoring Dashboards)
# =============================================================================
# Admin password for unified Grafana instance
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# RAY COMPUTE (Optional)
# =============================================================================
# API secret key for Ray Compute API
RAY_API_SECRET_KEY=change-me-in-production

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# OAuth enabled for Ray (true/false)
OAUTH_ENABLED=false

# =============================================================================
# INFERENCE MODELS (Optional)
# =============================================================================
# HuggingFace token for accessing gated models
HF_TOKEN=

# =============================================================================
# BACKUP CONFIGURATION (Optional)
# =============================================================================
# Backup schedule in cron format (default: 2am daily)
BACKUP_SCHEDULE=0 2 * * *

# Retention periods
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# Resource limits for backup container
BACKUP_CPU_LIMIT=0.5
BACKUP_MEM_LIMIT=256M

# Webhook for backup notifications (optional)
BACKUP_WEBHOOK_URL=

# =============================================================================
# WEBHOOKS & NOTIFICATIONS (Optional)
# =============================================================================
# GitHub webhook secret for automated deployments
GITHUB_WEBHOOK_SECRET=

# FusionAuth webhook secret for user registration notifications
FUSIONAUTH_WEBHOOK_SECRET=

# Telegram bot for notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email for deployment notifications
DEPLOY_NOTIFICATION_EMAIL=

# =============================================================================
# SECURITY (Optional)
# =============================================================================
# GitGuardian API key for secret scanning
GITGUARDIAN_API_KEY=

# =============================================================================
# QUICK SETUP COMMANDS
# =============================================================================
# Generate all secrets at once:
#
#   SHARED_DB_PASSWORD=$(openssl rand -base64 32)
#   FUSIONAUTH_API_KEY=$(openssl rand -hex 32)
#   GRAFANA_ADMIN_PASSWORD=$(openssl rand -base64 24)
#   OAUTH2_PROXY_COOKIE_SECRET=$(python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())')
#
# Create secret files:
#
#   mkdir -p secrets
#   echo "$SHARED_DB_PASSWORD" > secrets/shared_db_password.txt
#   echo "$GRAFANA_ADMIN_PASSWORD" > secrets/grafana_password.txt
#   echo "$OAUTH2_PROXY_COOKIE_SECRET" > secrets/oauth2_proxy_cookie_secret.txt
#
# Start the platform:
#
#   ./start_all_safe.sh
