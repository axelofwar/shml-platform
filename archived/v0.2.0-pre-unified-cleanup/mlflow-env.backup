# MLflow Server Environment Configuration
# ==================================================
# Copy this file to .env and update with your actual values
# WARNING: Never commit .env to version control!

# Network Configuration
# ---------------------
# Your server's local IP address
SERVER_LOCAL_IP=10.0.0.163

# Your Tailscale VPN IP (stable across restarts)
SERVER_TAILSCALE_IP=100.80.251.28

# Training/client machine IP
CLIENT_IP=10.0.0.163

# MLflow Configuration
# ---------------------
# Tracking URI for remote connections (use Tailscale IP for secure remote access)
MLFLOW_TRACKING_URI=http://${SERVER_TAILSCALE_IP}:8080

# Database Configuration
# ----------------------
# PostgreSQL connection details
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mlflow_db
POSTGRES_USER=mlflow

# Database password (automatically generated by deploy.sh)
# This is read from secrets/db_password.txt at runtime
DB_PASSWORD=sotawGWvpf9sY4c3KuIFOcXrKzEnbCKp

# Backend store URI for MLflow server
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:sotawGWvpf9sY4c3KuIFOcXrKzEnbCKp@postgres:5432/mlflow_db

# Artifact storage (using local filesystem with HTTP proxy)
MLFLOW_ARTIFACT_ROOT=mlflow-artifacts:/

# Deployment Settings
# -------------------
COMPOSE_PROJECT_NAME=mlflow-production
COMPOSE_FILE=docker-compose.yml

# Performance Settings (optimized for your hardware)
# ---------------------------------------------------
# PostgreSQL
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# MLflow/Gunicorn Workers
MLFLOW_WORKERS=8
MLFLOW_WORKER_CLASS=gevent
MLFLOW_WORKER_CONNECTIONS=2000
MLFLOW_WORKER_TIMEOUT=3600

# Redis Cache
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Nginx Configuration
# -------------------
NGINX_PORT=8080
NGINX_MAX_UPLOAD_SIZE=2560M
NGINX_CLIENT_BODY_TIMEOUT=1800
NGINX_PROXY_READ_TIMEOUT=1800

# Service Ports (Internal)
# -------------------------
MLFLOW_PORT=5000
ADMINER_PORT=8081
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# Backup Configuration
# --------------------
# How many days to keep backups (0 = forever)
BACKUP_RETENTION_DAYS=90
BACKUP_RETENTION_PRODUCTION=0

# Backup schedule (cron format)
BACKUP_TIME="0 2 * * *"  # Daily at 2 AM

# Monitoring & Logging
# --------------------
LOG_LEVEL=INFO
METRICS_ENABLED=true
