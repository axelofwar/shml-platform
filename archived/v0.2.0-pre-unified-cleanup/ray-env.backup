# =============================================================================
# API SERVER (Not Deployed)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8266
API_SECRET_KEY=IVPDPJSpiPBQauUHvSuINUeaisVOMpjSSNZE27YxS7Vkr8eRMnssYaweSYKxN9Dr
