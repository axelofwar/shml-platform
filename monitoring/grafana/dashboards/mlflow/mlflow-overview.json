{
  "annotations": { "list": [] },
  "description": "MLflow tracking server and enhanced API health, throughput, latency, and error rates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "MLflow UI",
      "url": "/mlflow/",
      "targetBlank": true,
      "icon": "external link"
    },
    {
      "title": "Platform Overview",
      "url": "/grafana/d/platform-overview",
      "targetBlank": false,
      "icon": "apps"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "API Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "up{job=\"mlflow-api\"}",
          "refId": "A",
          "legendFormat": "Status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP", "color": "green" },
                "0": { "text": "DOWN", "color": "red" }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "DOWN", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "Tracking Server Up",
      "type": "stat",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "up{job=\"mlflow-server\"}",
          "refId": "A",
          "legendFormat": "Status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP", "color": "green" },
                "0": { "text": "DOWN", "color": "red" }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "DOWN", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "mlflow_api_active_requests",
          "refId": "A",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Request Rate (5m)",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum(rate(mlflow_api_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "title": "Error Rate (5m)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum(rate(mlflow_api_requests_total{status=~\"4..|5..\"}[5m])) / sum(rate(mlflow_api_requests_total[5m])) * 100",
          "refId": "A",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(mlflow_api_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 7,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum by(endpoint) (rate(mlflow_api_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(mlflow_api_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(mlflow_api_request_duration_seconds_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(mlflow_api_request_duration_seconds_bucket[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "title": "HTTP Status Distribution",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum by(status) (rate(mlflow_api_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "HTTP 200" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 4.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 5.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "title": "Auth Failures",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum by(method) (rate(mlflow_api_auth_failures_total[5m]))",
          "refId": "A",
          "legendFormat": "Auth failure ({{method}})"
        },
        {
          "expr": "sum by(user_tier) (rate(mlflow_api_rate_limit_hits_total[5m]))",
          "refId": "B",
          "legendFormat": "Rate limited ({{user_tier}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "A" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byFrameRefID", "options": "B" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "title": "Upload / Download Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "sum(rate(mlflow_api_upload_bytes_sum[5m]))",
          "refId": "A",
          "legendFormat": "Upload"
        },
        {
          "expr": "sum(rate(mlflow_api_download_bytes_sum[5m]))",
          "refId": "B",
          "legendFormat": "Download"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "title": "Request Latency by Endpoint (p95, heatmap)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "mlflow-metrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(endpoint, le) (rate(mlflow_api_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{endpoint}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 13,
      "title": "MLflow API — Container CPU",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "global-metrics" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"mlflow.*\"}[5m]) * 100",
          "refId": "A",
          "legendFormat": "{{name}} CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 14,
      "title": "MLflow API — Container Memory",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "global-metrics" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"mlflow.*\"} / 1024 / 1024",
          "refId": "A",
          "legendFormat": "{{name}} MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["mlflow", "api", "tracking"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MLflow Overview",
  "uid": "mlflow-overview",
  "version": 1
}
