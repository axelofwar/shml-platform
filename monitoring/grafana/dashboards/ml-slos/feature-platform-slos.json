{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Feature Platform — per-view freshness, SLO compliance, materialization health (EB-05).",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": ["ml", "slo"],
      "title": "ML Platform SLOs",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Per-feature-view freshness in minutes. Each bar is one feature view.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"-1": {"color": "dark-gray", "text": "No Data"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "orange", "value": 120},
              {"color": "red", "value": 1440}
            ]
          },
          "unit": "m",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "ml_feature_view_freshness_minutes",
          "refId": "A",
          "legendFormat": "{{feature_view}}"
        }
      ],
      "title": "Feature View Freshness (per view)",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "1 = SLO met (feature is fresh), 0 = SLO breached (feature is stale). Per feature view.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "BREACHED"}, "1": {"color": "green", "text": "MET"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "ml_feature_view_slo_met",
          "refId": "A",
          "legendFormat": "{{feature_view}}"
        }
      ],
      "title": "SLO Compliance (per view)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Freshness over time per feature view — shows materialization cadence and any gaps.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "Minutes",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": {"mode": "none"}
          },
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "ml_feature_view_freshness_minutes",
          "refId": "A",
          "legendFormat": "{{feature_view}}"
        },
        {
          "expr": "ml_feature_view_slo_target_minutes",
          "refId": "B",
          "legendFormat": "SLO: {{feature_view}}"
        }
      ],
      "title": "Freshness Over Time (with SLO targets)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Configured SLO target per feature view.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          },
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "ml_feature_view_slo_target_minutes",
          "refId": "A",
          "legendFormat": "{{feature_view}}"
        }
      ],
      "title": "SLO Targets",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Overall platform freshness — global metric across all feature tables.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 120}
            ]
          },
          "unit": "m",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "ml_feature_freshness_minutes",
          "refId": "A",
          "legendFormat": "Global Feature Freshness"
        }
      ],
      "title": "Global Feature Freshness",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Number of views currently breaching their freshness SLO.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "count(ml_feature_view_slo_met == 0) or vector(0)",
          "refId": "A",
          "legendFormat": "SLO Breaches"
        }
      ],
      "title": "Views Breaching SLO",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "global-metrics"},
      "description": "Number of views currently meeting their freshness SLO.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "dark-red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "count(ml_feature_view_slo_met == 1) or vector(0)",
          "refId": "A",
          "legendFormat": "Healthy Views"
        }
      ],
      "title": "Views Meeting SLO",
      "type": "stat"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ml", "features", "slo", "platform", "eb-05"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Feature Platform — Per-View SLOs",
  "uid": "feature-platform-slos",
  "version": 1
}
