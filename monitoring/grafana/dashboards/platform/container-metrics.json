      "panels": [],
      "title": "Container ID → Name Mapping",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Reference this table to identify containers in the charts below. Short ID matches the legend labels.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Short ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Container Name"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Memory (MB)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "min",
                "value": 0
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 50,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": true,
          "fields": "",
          "reducer": ["count"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Memory (MB)"
          }
        ]
      },
      "pluginVersion": "10.2.2",
      "targets": [
        {
          "datasource": "${datasource}",
          "editorMode": "code",
          "exemplar": false,
          "expr": "container_memory_usage_bytes{container_short_id!=\"\"} / 1024 / 1024 * on(container_short_id) group_left(container_name) container_info",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Memory"
        },
        {
          "datasource": "${datasource}",
          "editorMode": "code",
          "exemplar": false,
          "expr": "rate(container_cpu_usage_seconds_total{container_short_id!=\"\"}[5m]) * 100 * on(container_short_id) group_left(container_name) container_info",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "CPU"
        }
      ],
      "title": "Container ID → Name Mapping (use Short ID to identify containers in charts)",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "container_short_id"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "component": true,
              "component 1": true,
              "component 2": true,
              "cpu": true,
              "id": true,
              "id 1": true,
              "id 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "container_name 2": true
            },
            "indexByName": {
              "container_name 1": 0,
              "container_short_id": 1,
              "Value #Memory": 2,
              "Value #CPU": 3
            },
            "renameByName": {
              "Value #CPU": "CPU %",
              "Value #Memory": "Memory (MB)",
              "container_short_id": "Short ID",
              "container_name 1": "Container Name"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Container Name",
            "mode": "reduceRow",
            "reduce": {
              "include": ["Short ID"],
              "reducer": "first"
            },
            "replaceFields": false
          }
        }
      ],
      "type": "table"
    },
