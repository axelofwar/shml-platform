# =============================================================================
# SHML Platform - Centralized Configuration
# =============================================================================
# Maps 1:1 to K8s ConfigMap when migrating
# Usage: env_file: - ../config/platform.env (in docker-compose services)
#
# NOTE: Secrets (passwords, tokens, keys) belong in secrets/ files,
# NOT in this env file. This file is for non-sensitive configuration only.
# =============================================================================

# ---------------------------------------------------------------------------
# Service Discovery (Docker DNS names = K8s service names)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow-nginx:80
MLFLOW_REGISTRY_MODEL_NAME=face-detection-yolov8l-p2
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ---------------------------------------------------------------------------
# Model & Data Storage (host paths for volume mounts)
# ---------------------------------------------------------------------------
# Canonical host directories — bind-mounted into training containers.
# Create these on the host machine before first training run:
#   sudo mkdir -p /opt/shml/models /opt/shml/data
#   sudo chown -R $USER /opt/shml
SHML_MODELS_DIR=/opt/shml/models
SHML_DATA_DIR=/opt/shml/data
# MLflow model registry names
MLFLOW_BASE_MODEL_YOLO11M=base-yolo11m
MLFLOW_BASE_MODEL_YOLO26N=base-yolo26n
MLFLOW_FACE_DETECT_MODEL=face-detection-yolov8l-p2

# ---------------------------------------------------------------------------
# Ray Compute
# ---------------------------------------------------------------------------
RAY_HEAD_ADDRESS=ray-head:6379
RAY_DASHBOARD_HOST=ray-head
RAY_DASHBOARD_PORT=8265
RAY_ADDRESS=http://ray-head:8265

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_HOST=global-prometheus
PROMETHEUS_PORT=9090
GRAFANA_HOST=unified-grafana
GRAFANA_PORT=3000
PUSHGATEWAY_HOST=pushgateway
PUSHGATEWAY_PORT=9091

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOKI_HOST=loki
LOKI_PORT=3100

# ---------------------------------------------------------------------------
# Tracing
# ---------------------------------------------------------------------------
TEMPO_HOST=tempo
TEMPO_PORT=3200
OTEL_COLLECTOR_HOST=otel-collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
FUSIONAUTH_HOST=fusionauth
FUSIONAUTH_PORT=9011
OAUTH2_PROXY_HOST=oauth2-proxy
OAUTH2_PROXY_PORT=4180

# ---------------------------------------------------------------------------
# Secrets Management
# ---------------------------------------------------------------------------
INFISICAL_HOST=infisical
INFISICAL_PORT=8080

# ---------------------------------------------------------------------------
# Platform Metadata
# ---------------------------------------------------------------------------
PLATFORM_VERSION=2.0
PLATFORM_ENV=production
PLATFORM_PREFIX=shml

# ---------------------------------------------------------------------------
# Container Registry
# ---------------------------------------------------------------------------
# GitLab CE container registry (self-hosted, Docker network hostname)
GITLAB_REGISTRY_HOST=registry.shml-gitlab:8929
# Image prefix for all platform-built services:
#   registry.shml-gitlab:8929/shml/platform/<service>:<tag>
# Fallback "shml/local" is used when building locally without registry push.
SHML_REGISTRY_IMAGE_PREFIX=registry.shml-gitlab:8929/shml/platform
SHML_IMAGE_TAG=latest
# Base images used by inference Dockerfiles (see docker/base/)
SHML_BASE_REGISTRY=registry.shml-gitlab:8929/shml/platform/base
SHML_BASE_TAG=latest

# ---------------------------------------------------------------------------
# NemoClaw / OpenShell (Agentic OS Layer)
# ---------------------------------------------------------------------------
NEMOCLAW_FACTORY_HOST=nemoclaw-sandbox-factory
NEMOCLAW_FACTORY_PORT=9095
NEMOCLAW_FACTORY_URL=http://nemoclaw-sandbox-factory:9095
NEMOCLAW_GATEWAY_HOST=openshell-gateway
NEMOCLAW_GATEWAY_PORT=9090
NEMOCLAW_GATEWAY_URL=http://openshell-gateway:9090
NEMOCLAW_BLUEPRINTS_PATH=/opt/shml-platform/nemoclaw-blueprint
NEMOCLAW_DEFAULT_BLUEPRINT=shml-base
# Fallback to legacy Docker sandbox if OpenShell factory unavailable (alpha software)
NEMOCLAW_FALLBACK_TO_DOCKER=true
# Platform Docker network CIDR (allowlisted in all blueprints)
# IMPORTANT: verify this matches your docker network inspect output
PLATFORM_CIDR=172.20.0.0/16
# Cloud escalation via NemoClaw nimcloud profile (requires NVIDIA_API_KEY secret)
# Set to true once NVIDIA_API_KEY is configured in Infisical
NEMOCLAW_CLOUD_PROFILE_ENABLED=false
# Nemotron model name served by local vLLM (nemotron container)
NEMOTRON_MODEL=nvidia/nemotron-3-nano-30b-a3b
# Cloud model for nimcloud escalation
OPENSHELL_CLOUD_MODEL=nvidia/nemotron-3-super-120b-a12b
OPENSHELL_CLOUD_ENDPOINT=https://integrate.api.nvidia.com/v1
