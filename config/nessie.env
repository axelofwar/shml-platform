# =============================================================================
# Nessie Catalog Configuration
# =============================================================================
# Iceberg catalog with Git-like version control (branching, tagging, merge).
# All Spark/PyIceberg clients should source this file.
#
# Usage in docker-compose:
#   env_file:
#     - ../config/nessie.env
# =============================================================================

# Nessie REST API endpoint
NESSIE_URI=http://nessie:19120/api/v2

# Default Iceberg warehouse path
ICEBERG_WAREHOUSE=/data/iceberg-warehouse

# Default branch
NESSIE_DEFAULT_REF=main

# Iceberg Spark runtime JAR
ICEBERG_JAR=org.apache.iceberg:iceberg-spark-runtime-4.0_2.13:1.10.1
