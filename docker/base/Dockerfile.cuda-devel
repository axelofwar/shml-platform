# SHML Base Image: CUDA Devel (Triton JIT)
# Inherits: nvidia/cuda:12.4.1-devel-ubuntu22.04
# Used by: inference/coding-model (vLLM + Triton JIT compilation for older GPUs)
#
# NOTE: This image is intentionally larger (~6GB) due to devel headers needed
# for Triton JIT kernel compilation at runtime (RTX 2070 sm_75 target).
#
# Registry: ${SHML_REGISTRY_IMAGE_PREFIX}/base-cuda-devel:${SHML_IMAGE_TAG}

FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_HOME=/models \
    HOST=0.0.0.0 \
    PORT=8000

# Python 3.11 devel + GCC/G++ required for Triton JIT compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
        python3.11-dev \
        python3-pip \
        curl \
        ca-certificates \
        gcc \
        g++ \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3 \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — note: coding-model may need to run as root for some vLLM ops;
# set USER at the service Dockerfile level if needed
RUN useradd -m -u 1000 -s /bin/bash inference

WORKDIR /app

HEALTHCHECK --interval=60s --timeout=30s --start-period=300s --retries=3 \
    CMD curl -sf http://localhost:8000/health || exit 1

EXPOSE 8000
