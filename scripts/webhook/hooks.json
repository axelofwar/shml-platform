[
  {
    "id": "github-deploy",
    "execute-command": "/scripts/webhook/deploy.sh",
    "command-working-directory": "/opt/shml-platform",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "repository.full_name" },
      { "source": "payload", "name": "ref" },
      { "source": "payload", "name": "head_commit.message" },
      { "source": "payload", "name": "pusher.name" }
    ],
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv \"GITHUB_WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    },
    "include-command-output-in-response": true,
    "response-message": "Deployment triggered"
  },
  {
    "id": "fusionauth-user-registration",
    "execute-command": "/scripts/webhook/notify_user_registration.sh",
    "command-working-directory": "/opt/shml-platform",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "event.user.email" },
      { "source": "payload", "name": "event.user.username" },
      { "source": "payload", "name": "event.user.id" },
      { "source": "payload", "name": "event.registration.applicationId" },
      { "source": "payload", "name": "event.type" }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv \"FUSIONAUTH_WEBHOOK_SECRET\" }}",
        "parameter": {
          "source": "header",
          "name": "X-FusionAuth-Webhook-Secret"
        }
      }
    },
    "include-command-output-in-response": false,
    "response-message": "User registration notification processed"
  },
  {
    "id": "gitlab-mirror-sync",
    "execute-command": "/scripts/webhook/deploy.sh",
    "command-working-directory": "/opt/shml-platform",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "project.path_with_namespace" },
      { "source": "payload", "name": "ref" },
      { "source": "payload", "name": "commits.0.message" },
      { "source": "payload", "name": "user_username" }
    ],
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "value",
            "value": "{{ getenv \"GITLAB_WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Gitlab-Token"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    },
    "include-command-output-in-response": true,
    "response-message": "GitLab mirror sync triggered"
  },
  {
    "id": "health",
    "execute-command": "/bin/echo",
    "pass-arguments-to-command": [
      { "source": "string", "name": "healthy" }
    ],
    "response-message": "Webhook service is healthy"
  },
  {
    "id": "autoresearch-complete",
    "execute-command": "/scripts/webhook/handle_autoresearch_complete.sh",
    "command-working-directory": "/opt/shml-platform",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "experiment" },
      { "source": "payload", "name": "iteration" },
      { "source": "payload", "name": "kept" },
      { "source": "payload", "name": "metrics.recall" },
      { "source": "payload", "name": "metrics.mAP50" },
      { "source": "payload", "name": "best_recall" },
      { "source": "payload", "name": "reason" }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "experiment_complete",
        "parameter": { "source": "payload", "name": "type" }
      }
    },
    "include-command-output-in-response": true,
    "response-message": "Autoresearch event processed"
  },
  {
    "id": "watchdog-alert",
    "execute-command": "/scripts/webhook/handle_watchdog_alert.sh",
    "command-working-directory": "/opt/shml-platform",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "alert_type" },
      { "source": "payload", "name": "service" },
      { "source": "payload", "name": "message" },
      { "source": "payload", "name": "severity" }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "shml:health:alert",
        "parameter": { "source": "payload", "name": "channel" }
      }
    },
    "include-command-output-in-response": false,
    "response-message": "Watchdog alert processed"
  },
  {
    "id": "gitlab-events",
    "execute-command": "/bin/echo",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "object_kind" },
      { "source": "payload", "name": "object_attributes.state" }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv \"GITLAB_WEBHOOK_SECRET\" }}",
        "parameter": { "source": "header", "name": "X-Gitlab-Token" }
      }
    },
    "include-command-output-in-response": false,
    "response-message": "GitLab event received"
  }
]
