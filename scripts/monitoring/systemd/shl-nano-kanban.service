[Unit]
Description=SHL Nano Kanban updater — sync pipeline state to Obsidian
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/Projects/shml-platform
ExecStart=/usr/bin/env bash -lc '\
    exec bash "$HOME/Projects/shml-platform/scripts/data/update_kanban.sh"'
TimeoutStartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
