{
    "$schema": "https://mcp.dev/schema.json",
    "mcpServers": {
        "shml-platform": {
            "name": "SHML Platform MCP",
            "description": "Training status, GPU info, MLflow queries, Vision analysis",
            "transport": {
                "type": "http",
                "url": "http://localhost/api/agent/mcp"
            },
            "capabilities": {
                "tools": true,
                "resources": false,
                "sampling": false
            }
        },
        "filesystem-DISABLED": {
            "_SECURITY_NOTE": "DISABLED - grants read/write access to entire platform directory including secrets/. Use admin-only scoped access instead.",
            "name": "File System (DISABLED)",
            "description": "SECURITY: Disabled - was granting model access to secrets/ directory",
            "transport": {
                "type": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "/home/axelofwar/Projects/shml-platform"
                ]
            },
            "capabilities": {
                "tools": true,
                "resources": true,
                "sampling": false
            }
        },
        "git": {
            "name": "Git Operations",
            "description": "Git operations for version control",
            "transport": {
                "type": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-git",
                    "--repository",
                    "/home/axelofwar/Projects/shml-platform"
                ]
            },
            "capabilities": {
                "tools": true,
                "resources": true,
                "sampling": false
            }
        },
        "brave-search": {
            "name": "Brave Search",
            "description": "Web search via Brave Search API",
            "transport": {
                "type": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-brave-search"
                ]
            },
            "env": {
                "BRAVE_API_KEY": "${BRAVE_API_KEY}"
            },
            "capabilities": {
                "tools": true,
                "resources": false,
                "sampling": false
            }
        }
    },
    "globalConfig": {
        "workspace": "/home/axelofwar/Projects/shml-platform",
        "safetyMode": "training-aware",
        "notes": [
            "SHML Platform MCP integrates with Ray training and MLflow",
            "Vision tools (RTX 2070) are always safe during training",
            "Code gen tools (RTX 3090 Ti) are blocked during training",
            "Use 'training_status' tool to check before heavy operations"
        ]
    }
}
